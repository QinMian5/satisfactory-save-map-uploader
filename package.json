{
  "name": "satisfactory-save-map-uploader",
  "productName": "Satisfactory Save Map Uploader",
  "version": "0.2.0",
  "description": "Desktop uploader that provides selected Satisfactory saves to the Satisfactory Calculator interactive map.",
  "private": true,
  "author": "Mian Qin",
  "license": "MIT",
  "type": "module",
  "main": ".vite/build/app.js",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "electron-forge start",
    "build": "tsc -p tsconfig.json --noEmit",
    "start": "electron-forge start",
    "package": "node scripts/package-windows.mjs",
    "make": "node scripts/make-windows.mjs nsis zip",
    "make:installer": "node scripts/make-windows.mjs nsis",
    "make:portable": "node scripts/make-windows.mjs zip",
    "make:appx": "node scripts/make-windows.mjs appx",
    "verify:package": "node scripts/verify-package.mjs package",
    "verify:make": "node scripts/verify-package.mjs make",
    "verify:installer": "node scripts/verify-package.mjs installer",
    "verify:portable": "node scripts/verify-package.mjs portable",
    "verify:appx": "node scripts/verify-package.mjs appx",
    "smoke:package": "node scripts/smoke-package.mjs",
    "integration:package": "node scripts/integration-package.mjs",
    "lint": "biome ci .",
    "fix": "biome check --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest --run",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "hooks:install": "uv run pre-commit install --hook-type pre-commit --hook-type commit-msg"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "overrides": {
      "esbuild": "0.28.1",
      "tar": "7.5.16",
      "tmp": "0.2.7"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron-forge/shared-types": "^7.11.2",
    "@electron/asar": "^3.4.1",
    "@electron/fuses": "^1.8.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^7.3.5",
    "vitest": "^4.1.8"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.17",
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwind-merge": "^3.6.0"
  }
}
